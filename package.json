{
	"name": "pi-desktop",
	"version": "0.0.0",
	"description": "Open-source desktop command center for the Pi coding agent CLI.",
	"private": true,
	"type": "module",
	"main": ".vite/build/main.js",
	"productName": "pi-desktop",
	"packageManager": "pnpm@11.1.1",
	"engines": {
		"node": ">=24 <25"
	},
	"scripts": {
		"preinstall": "node ./scripts/check-node-version.mjs",
		"dev": "pnpm dev:desktop",
		"dev:desktop": "node --env-file-if-exists=.env.development --run forge:start",
		"forge:start": "PNPM_CONFIG_NODE_LINKER=hoisted electron-forge start",
		"dev:web": "node --env-file-if-exists=.env.development --import tsx src/main/dev-server/start-dev-web.ts",
		"build": "PNPM_CONFIG_NODE_LINKER=hoisted electron-forge package",
		"package": "PNPM_CONFIG_NODE_LINKER=hoisted electron-forge package",
		"make": "PNPM_CONFIG_NODE_LINKER=hoisted electron-forge make",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"lint": "biome lint .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:smoke": "pnpm build && playwright test --config playwright.config.ts",
		"test:smoke:headed": "PI_DESKTOP_SMOKE_HEADED=1 pnpm test:smoke",
		"test:uat": "playwright test --config playwright.uat.config.ts",
		"check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test:coverage && pnpm test:smoke",
		"prepare": "husky"
	},
	"dependencies": {
		"@codemirror/commands": "6.10.3",
		"@codemirror/lang-css": "6.3.1",
		"@codemirror/lang-go": "6.0.1",
		"@codemirror/lang-html": "6.4.11",
		"@codemirror/lang-javascript": "6.2.5",
		"@codemirror/lang-json": "6.0.2",
		"@codemirror/lang-python": "6.2.1",
		"@codemirror/lang-rust": "6.0.2",
		"@codemirror/lang-sql": "6.10.0",
		"@codemirror/lang-xml": "6.1.0",
		"@codemirror/lang-yaml": "6.1.3",
		"@codemirror/language": "6.12.3",
		"@codemirror/legacy-modes": "6.5.3",
		"@codemirror/search": "6.7.0",
		"@codemirror/state": "6.6.0",
		"@codemirror/view": "6.43.0",
		"@earendil-works/pi-coding-agent": "0.74.0",
		"@lezer/highlight": "1.2.3",
		"@mdxeditor/editor": "4.0.1",
		"@mdxeditor/gurx": "1.2.4",
		"@radix-ui/number": "1.1.1",
		"@radix-ui/primitive": "1.1.3",
		"@radix-ui/react-compose-refs": "1.1.2",
		"@radix-ui/react-context": "1.1.2",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-direction": "1.1.1",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-presence": "1.1.5",
		"@radix-ui/react-primitive": "2.1.4",
		"@radix-ui/react-scroll-area": "^1.2.10",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-use-callback-ref": "1.1.1",
		"@radix-ui/react-use-layout-effect": "1.1.1",
		"agentation": "^3.0.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"docx-preview": "^0.3.7",
		"dompurify": "^3.4.5",
		"jszip": "^3.10.1",
		"lucide-react": "^1.14.0",
		"marked": "^18.0.3",
		"pdfjs-dist": "5.4.394",
		"prismjs": "1.30.0",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"scheduler": "0.27.0",
		"tailwind-merge": "^3.6.0",
		"ws": "^8.20.1",
		"xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@electron-forge/cli": "^7.11.1",
		"@electron-forge/maker-zip": "^7.11.1",
		"@electron-forge/plugin-vite": "^7.11.1",
		"@electron-forge/shared-types": "7.11.1",
		"@playwright/test": "^1.59.1",
		"@tailwindcss/vite": "^4.3.0",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^24.12.3",
		"@types/prismjs": "^1.26.6",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/ws": "^8.18.1",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/coverage-v8": "^4.1.6",
		"electron": "^42.0.1",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.22.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.12",
		"vitest": "^4.1.6"
	}
}
